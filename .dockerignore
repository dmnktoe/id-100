README.md
*.md

# Development files
.env
.env.local
.env.example
.air.toml

# Build artifacts
bin/
id-100
*.exe

# Node modules
node_modules/

# Test files
**/*_test.go
**/*.test.ts

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.yml
Dockerfile
.dockerignore
